[Unit]
Description=Gradescope missing-submission reminders
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/gradescope-missing-submission-reminders
EnvironmentFile=%h/.config/gradescope-reminder/secrets.env
ExecStart=%h/gradescope-missing-submission-reminders/.venv/bin/python reminder.py --send

[Install]
WantedBy=default.target
